@rendermode InteractiveServer

<div class="card p-4 m-3 shadow-sm rounded-4 border-0" style="background-color: #f8fcf8;">
    <h3 class="text-success mb-3" style="font-weight: 600;">@Titulo</h3>

    <div class="mb-3">
        <span style="font-size: 1.1rem; color: #555;">Impacto Acumulado:</span>
        <strong class="d-block mt-1 transition-color" style="color:@CorTexto; font-size: 2rem;">
            @Total pontos
        </strong>
    </div>

    <!-- Barra de Progresso (Desafio Extra) -->
    <div class="progress mb-4 rounded-pill" style="height: 25px; background-color: #e9ecef;">
        <div class="progress-bar @ProgressBarColor() progress-bar-striped progress-bar-animated" 
             role="progressbar" 
             style="width: @(Math.Min(ProgressoPerc, 100))%; transition: width 0.4s ease;" 
             aria-valuenow="@ProgressoPerc" 
             aria-valuemin="0" 
             aria-valuemax="100">
             <span class="fw-bold">@Math.Min(ProgressoPerc, 100)%</span>
        </div>
    </div>

    <button class="btn btn-success btn-lg w-100 fw-bold rounded-pill shadow-sm hover-elevate" 
            @onclick="SomarPontos">
        <i class="bi bi-plus-circle me-2"></i> + @Peso Pontos
    </button>

    <!-- Feedback Visual (Estilização Condicional) -->
    @if (MetaAtingida && !HeroiDoPlaneta)
    {
        <div class="alert alert-success mt-3 mb-0 p-2 text-center rounded-3 anim-fade-in" role="alert">
            <span class="fw-bold">🎉 Muito bem! Você atingiu a meta de 50 pontos.</span>
        </div>
    }

    <!-- Mensagem de Conquista (Desafio Extra) -->
    @if (HeroiDoPlaneta)
    {
        <div class="alert mt-3 mb-0 p-3 text-center rounded-3 anim-bounce" role="alert" style="background: linear-gradient(135deg, #ffd700, #ffaa00); color: #fff; border: none; box-shadow: 0 4px 15px rgba(255, 215, 0, 0.4);">
            <h5 class="mb-0 fw-bold">🌍 Você é um Herói do Planeta! 🦸‍♂️🦸‍♀️</h5>
            <small>Parabéns pelo impacto extraordinário!</small>
        </div>
    }
</div>

<style>
    .transition-color { transition: color 0.3s ease; }
    .hover-elevate { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .hover-elevate:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(25, 135, 84, 0.3) !important; }
    .anim-fade-in { animation: fadeIn 0.5s ease-in; }
    .anim-bounce { animation: bounce 0.8s ease-out; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes bounce {
        0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
        40% { transform: translateY(-15px); }
        60% { transform: translateY(-7px); }
    }
</style>

@code {
    [Parameter]
    public string Titulo { get; set; } = string.Empty;

    [Parameter]
    public int Peso { get; set; } = 1;

    private int Meta = 50;
    private int MetaHeroi = 100;
    private int Total = 0;

    private void SomarPontos()
    {
        Total += Peso;
    }

    // Estilização Condicional
    private string CorTexto => Total >= Meta ? "#198754" : "#212529";

    private bool MetaAtingida => Total >= Meta;
    private bool HeroiDoPlaneta => Total >= MetaHeroi;

    // Lógica para a barra de progresso
    private int ProgressoPerc => Total >= MetaHeroi ? 100 : (Total * 100) / MetaHeroi;
    
    private string ProgressBarColor()
    {
        if (HeroiDoPlaneta) return "bg-warning"; 
        if (MetaAtingida) return "bg-success"; 
        return "bg-info"; 
    }
}