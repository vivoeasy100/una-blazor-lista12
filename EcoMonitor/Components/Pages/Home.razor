@page "/"

<PageTitle>EcoMonitor</PageTitle>

<div class="container py-5">
    <div class="text-center mb-5">
        <div class="d-inline-flex align-items-center justify-content-center bg-success text-white rounded-circle mb-3" style="width: 80px; height: 80px;">
            <span style="font-size: 2.5rem;">🌱</span>
        </div>
        <h1 class="display-4 fw-bold" style="color: #2e7d32;">EcoMonitor</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">
            Registre suas ações sustentáveis e acompanhe seu impacto no meio ambiente crescer em tempo real.
        </p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <EcoStatus Titulo="Reciclagem de Plástico" Peso="1" />
            <EcoStatus Titulo="Plantio de Árvores" Peso="10" />
            <EcoStatus Titulo="Descarte de Eletrônicos" Peso="5" />
        </div>
    </div>
</div>